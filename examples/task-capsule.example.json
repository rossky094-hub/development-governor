{
  "schema_version": "development-governor-task-capsule.v2",
  "repo_path": "/absolute/path/to/your-project",
  "owner_request_ref": "owner:request/replace-with-real-reference",
  "result": "Deliver one observable, bounded product capability.",
  "primary_mode": "product",
  "capability_transition": {
    "capability_id": "replace-with-capability-id",
    "from_state": "replace-with-observed-before-state",
    "to_state": "replace-with-accepted-after-state"
  },
  "constraints": [
    "Do not modify protected acceptance material.",
    "Do not claim completion before frozen verification passes."
  ],
  "evidence_inputs": [
    {
      "path": "README.md",
      "sha256": "replace-with-lowercase-sha256"
    },
    {
      "path": "acceptance/run_tests.py",
      "sha256": "replace-with-lowercase-sha256"
    }
  ],
  "acceptance_ids": [
    "unit-tests"
  ],
  "deliverable_paths": [
    "src/feature.py",
    "tests/test_feature.py"
  ],
  "product_evidence_paths": [
    "src/feature.py"
  ],
  "limits": {
    "max_attempts": 1,
    "max_review_waves": 0,
    "max_elapsed_seconds": 3600,
    "lease_seconds": 3600,
    "max_parallel_agents": 1,
    "max_total_agents": 1
  },
  "lanes": []
}
